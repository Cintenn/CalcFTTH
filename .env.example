# Database Configuration
# Required: PostgreSQL connection string
DATABASE_URL="postgres://user:password@localhost:5432/ftth"

# API Server Configuration
# Port for the API server (default: 3000)
PORT=3000

# JWT Secret
# Required: Secret key for signing JWT tokens (use a strong, random string in production)
SESSION_SECRET="your-secure-random-jwt-secret-key-here"

# Admin User Configuration  
# Required: Default admin username (default: maul)
ADMIN_USERNAME="maul"

# Required: Default admin password (use a strong password in production)
ADMIN_PASSWORD="your-secure-admin-password-here"

# Environment
# Set to "production" for production builds
NODE_ENV="development"

# Logging
# Log level: debug, info, warn, error
LOG_LEVEL="info"

# Frontend Configuration
# Port for Vite dev server (default: 5173)
PORT=5173

# Base path for the application (default: /)
BASE_PATH="/"

# API URL (for frontend to communicate with API)
# In production, set this to your API server URL
VITE_API_URL="http://localhost:3000/api"

shamefully-hoist=true

# Production optimization settings
# Use hardlinks for faster installs and disk space savings
link-workspace-packages=true

# Don't auto-update packages
auto-install-peers=false

# Strict peer dependency resolution
strict-peer-dependencies=false

# Use prefer offline mode for faster CI/CD builds
prefer-offline=false

# Require lockfile version for consistency
lockfile-only=false

